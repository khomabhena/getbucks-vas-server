# VAS server — copy to .env on VM: /home/adminuser/vas/getbucks-vas-server/.env
# Secrets stay on the server only.

PORT=3001

# H5 iframe JWT (iBank / mobile banking)
IBANK_CLIENT_ID=
IBANK_CLIENT_SECRET=
JWT_SECRET=
TOKEN_EXPIRES_IN=25m
TOKEN_EXPIRES_IN_SECONDS=1500

AIRTIME_APP_URL=https://h5-getbucks-airtime.vercel.app
BILL_PAYMENTS_APP_URL=https://h5-getbucks-bill-payments.vercel.app

# VAS Live catalog + PostPayment (required for /api/vas/*)
VAS_API_BASE_URL=https://vas-live.azurewebsites.net
VAS_SUBSCRIPTION_KEY=
VAS_MERCHANT_ID=
VAS_SIGNATURE=

# Upstream PostPayment POS shape (matches working Postman / till)
VAS_PAYMENT_CHANNEL=CASH
VAS_POS_STORE_ID=KWAMEH
VAS_POS_TERMINAL_ID=Terminal 23
VAS_POS_CASHIER_ID=Monzeni S
VAS_CUSTOMER_ID=WALKINCUSTOMER

# BankWare OpenAPI (required for /api/getbucks/*) — must be reachable FROM THIS HOST
BANKWARE_API_BASE_URL=http://s-bwopenapi.getbucks.co.zw
BANKWARE_USERNAME=
BANKWARE_PASSWORD=
BANKWARE_SYSTEM_ID=live
BANKWARE_GRANT_TYPE=password

# BankWare settlement (credit) accounts exposed via GET /api/payment-config/merchant-account
BANKWARE_MERCHANT_ACCOUNT_BILL_PAYMENTS=00001501
BANKWARE_MERCHANT_ACCOUNT_AIRTIME=99900515
# Optional global fallback: BANKWARE_MERCHANT_ACCOUNT=
# Optional per-currency: BANKWARE_MERCHANT_ACCOUNT_BILL_PAYMENTS_USD=00001501

# Legacy aliases (optional if VAS_* set above)
# HOT_RECHARGE_POST_PAYMENT_URL=
# HOT_RECHARGE_SUBSCRIPTION_KEY=
# HOT_RECHARGE_MERCHANT_ID=
# HOT_RECHARGE_SIGNATURE=
