{
  "info": {
    "_postman_id": "d4e5f6a7-vas-bff-coll-0001",
    "name": "Getbucks VAS BFF",
    "description": "24-getbucks-vas-server — catalog and payment via `/api/vas/*`.\n\nMerchant headers are added by the BFF from server `.env`.\n\n**Catalog:** flat products OR category drill-down via `parentProduct` (airtime + bills). See `postman/CATALOG.md`.\n\n**Currency:** pass `currency=USD|ZWG|ZIG|ZWL` on products; default USD.\n\n**Prerequisites:** `npm run dev` on port 3001 with `VAS_*` set.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const rid = pm.variables.replaceIn('{{$guid}}');",
          "pm.collectionVariables.set('requestId', rid);",
          "pm.environment.set('requestId', rid);"
        ]
      }
    }
  ],
  "variable": [
    { "key": "bffBaseUrl", "value": "http://localhost:3001" },
    { "key": "requestId", "value": "" }
  ],
  "item": [
    {
      "name": "Status",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{bffBaseUrl}}/"
          }
        },
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{bffBaseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('BFF is up', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "H5 / iBank",
      "description": "Iframe token flow (unchanged paths). Set `iBankClientId` and `iBankClientSecret` in the environment from your server `.env`.",
      "item": [
        {
          "name": "Request token (airtime)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"{{iBankClientId}}\",\n  \"clientSecret\": \"{{iBankClientSecret}}\",\n  \"app\": \"airtime\",\n  \"sessionID\": \"{{sessionId}}\",\n  \"userId\": \"postman-user\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{bffBaseUrl}}/api/token/request"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.token) {",
                  "  pm.environment.set('h5Token', j.token);",
                  "  console.log('Saved h5Token');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Request token (bill-payments)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"{{iBankClientId}}\",\n  \"clientSecret\": \"{{iBankClientSecret}}\",\n  \"app\": \"bill-payments\",\n  \"sessionID\": \"{{sessionId}}\",\n  \"userId\": \"postman-user\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{bffBaseUrl}}/api/token/request"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.token) pm.environment.set('h5Token', j.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Validate token",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{h5Token}}" }
            ],
            "url": "{{bffBaseUrl}}/api/validate-token"
          }
        },
        {
          "name": "Tester config",
          "request": {
            "method": "GET",
            "url": "{{bffBaseUrl}}/api/tester-config"
          }
        },
        {
          "name": "Iframe config",
          "request": {
            "method": "GET",
            "url": "{{bffBaseUrl}}/api/iframe-config"
          }
        },
        {
          "name": "Sample iframe data",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{bffBaseUrl}}/api/sample-iframe-data?app={{h5App}}",
              "host": ["{{bffBaseUrl}}"],
              "path": ["api", "sample-iframe-data"],
              "query": [{ "key": "app", "value": "{{h5App}}", "description": "airtime | bill-payments" }]
            }
          }
        }
      ]
    },
    {
      "name": "VAS Catalog",
      "description": "Proxy to VAS `/V2/*`. Run in order:\n\n1 Services → 2 Countries → 3 Service providers → 4 Products → 5 Product by id\n\nIf step 4 returns `IsCategory: true`, use **Catalog — categories** folder with `parentProduct`.\n\nSee `postman/CATALOG.md`.",
      "item": [
        {
          "name": "0 — Connect",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{bffBaseUrl}}/api/vas/catalog/connect"
          }
        },
        {
          "name": "1 — List services",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{bffBaseUrl}}/api/vas/catalog/services"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.Services && j.Services.length) {",
                  "  console.log('Services — set serviceId to one of:');",
                  "  j.Services.forEach(s => console.log(`  ${s.Id} = ${s.Name}`));",
                  "  if (!pm.environment.get('serviceId')) {",
                  "    pm.environment.set('serviceId', String(j.Services[0].Id));",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1b — List services (filter by country)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{bffBaseUrl}}/api/vas/catalog/services?countryCode={{countryCode}}",
              "host": ["{{bffBaseUrl}}"],
              "path": ["api", "vas", "catalog", "services"],
              "query": [{ "key": "countryCode", "value": "{{countryCode}}" }]
            }
          }
        },
        {
          "name": "2 — List countries for service",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{bffBaseUrl}}/api/vas/catalog/countries?service={{serviceId}}",
              "host": ["{{bffBaseUrl}}"],
              "path": ["api", "vas", "catalog", "countries"],
              "query": [{ "key": "service", "value": "{{serviceId}}", "description": "e.g. 1=Airtime, 3=Bundles" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.Countries && j.Countries.length) {",
                  "  j.Countries.forEach(c => console.log(`  ${c.Code} = ${c.Name}`));",
                  "  pm.environment.set('countryCode', j.Countries[0].Code);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "3 — List service providers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{bffBaseUrl}}/api/vas/catalog/service-providers?countryCode={{countryCode}}&service={{serviceId}}",
              "host": ["{{bffBaseUrl}}"],
              "path": ["api", "vas", "catalog", "service-providers"],
              "query": [
                { "key": "countryCode", "value": "{{countryCode}}" },
                { "key": "service", "value": "{{serviceId}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.ServiceProviders && j.ServiceProviders.length) {",
                  "  j.ServiceProviders.forEach(p => console.log(`  ${p.Id} = ${p.Name}`));",
                  "  pm.environment.set('serviceProvider', j.ServiceProviders[0].Id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "4 — Products in service",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{bffBaseUrl}}/api/vas/catalog/products?countryCode={{countryCode}}&service={{serviceId}}",
              "host": ["{{bffBaseUrl}}"],
              "path": ["api", "vas", "catalog", "products"],
              "query": [
                { "key": "countryCode", "value": "{{countryCode}}" },
                { "key": "service", "value": "{{serviceId}}" },
                { "key": "serviceProvider", "value": "{{serviceProvider}}", "disabled": true },
                { "key": "serviceProviderId", "value": "{{serviceProvider}}", "disabled": true, "description": "H5 alias — forwarded as query if enabled" },
                { "key": "mobileNumber", "value": "{{mobileNumber}}", "disabled": true },
                { "key": "currency", "value": "{{currency}}", "disabled": true },
                { "key": "parentProduct", "value": "{{parentProductId}}", "disabled": true, "description": "Category id (PC_…) — loads child products" },
                { "key": "productType", "value": "VariableAmount", "disabled": true }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.Products && j.Products.length) {",
                  "  console.log(`Found ${j.Products.length} products`);",
                  "  j.Products.slice(0, 10).forEach(p => console.log(`  ${p.Id} | ${p.Name} | cat=${p.IsCategory} | ${p.Currency}`));",
                  "  const category = j.Products.find(p => p.IsCategory);",
                  "  const leaf = j.Products.find(p => !p.IsCategory && p.Price > 0) || j.Products.find(p => !p.IsCategory);",
                  "  if (category) {",
                  "    pm.environment.set('parentProductId', category.Id);",
                  "    console.log('Category found — run step 4b with parentProduct:', category.Id);",
                  "  }",
                  "  if (leaf) {",
                  "    pm.environment.set('productId', leaf.Id);",
                  "    if (pm.environment.get('serviceId') === '1') pm.environment.set('productIdAirtime', leaf.Id);",
                  "    if (pm.environment.get('serviceId') === '3') pm.environment.set('productIdBundle', leaf.Id);",
                  "  } else if (j.Products[0]) {",
                  "    pm.environment.set('productId', j.Products[0].Id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "5 — Product by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{bffBaseUrl}}/api/vas/catalog/products/{{productId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "const p = j.ServiceProduct || j;",
                  "if (p.Currency) pm.environment.set('currency', p.Currency);",
                  "if (p.ProductType === 'FixedAmount' && p.Price) {",
                  "  pm.environment.set('paymentAmount', String(p.Price));",
                  "  console.log('Set paymentAmount to product price:', p.Price);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Catalog — categories (parentProduct)",
      "description": "Hierarchical catalog: when `IsCategory: true`, drill down with `parentProduct`. Works for **airtime** (e.g. Buddie vouchers) and **bills** (grouped utilities/education).\n\nSee `postman/CATALOG.md`.",
      "item": [
        {
          "name": "Account currency (H5 flow)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{bffBaseUrl}}/api/accounts/{{accountNumber}}/currency"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.vasCurrency) {",
                  "  pm.environment.set('currency', j.vasCurrency);",
                  "  console.log('vasCurrency:', j.vasCurrency);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "4a — Airtime top-level (may return categories)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{bffBaseUrl}}/api/vas/catalog/products?countryCode={{countryCode}}&service=1&serviceProvider=PC_ECONET&currency={{currency}}",
              "host": ["{{bffBaseUrl}}"],
              "path": ["api", "vas", "catalog", "products"],
              "query": [
                { "key": "countryCode", "value": "{{countryCode}}" },
                { "key": "service", "value": "1" },
                { "key": "serviceProvider", "value": "PC_ECONET" },
                { "key": "currency", "value": "{{currency}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.Products) {",
                  "  j.Products.forEach(p => console.log(`${p.Id} | cat=${p.IsCategory} | ${p.Name}`));",
                  "  const cat = j.Products.find(p => p.IsCategory);",
                  "  if (cat) pm.environment.set('parentProductId', cat.Id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "4b — Products under category (parentProduct)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{bffBaseUrl}}/api/vas/catalog/products?parentProduct={{parentProductId}}&currency={{currency}}",
              "host": ["{{bffBaseUrl}}"],
              "path": ["api", "vas", "catalog", "products"],
              "query": [
                { "key": "parentProduct", "value": "{{parentProductId}}", "description": "Category id from step 4a (PC_…)" },
                { "key": "currency", "value": "{{currency}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.Products && j.Products.length) {",
                  "  const leaf = j.Products.find(p => !p.IsCategory) || j.Products[0];",
                  "  pm.environment.set('productId', leaf.Id);",
                  "  pm.environment.set('productIdAirtime', leaf.Id);",
                  "  if (leaf.Price) pm.environment.set('paymentAmount', String(leaf.Price));",
                  "  console.log('Leaf product:', leaf.Id, leaf.Name);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "4a — Bills top-level (electricity, service 6)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{bffBaseUrl}}/api/vas/catalog/products?countryCode={{countryCode}}&service=6&currency={{currency}}",
              "host": ["{{bffBaseUrl}}"],
              "path": ["api", "vas", "catalog", "products"],
              "query": [
                { "key": "countryCode", "value": "{{countryCode}}" },
                { "key": "service", "value": "6" },
                { "key": "currency", "value": "{{currency}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('serviceId', '6');",
                  "const j = pm.response.json();",
                  "if (j.Products) {",
                  "  const cat = j.Products.find(p => p.IsCategory);",
                  "  if (cat) {",
                  "    pm.environment.set('parentProductId', cat.Id);",
                  "    console.log('Bill category — run 4b with', cat.Id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "5 — Leaf product by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{bffBaseUrl}}/api/vas/catalog/products/{{productId}}?currency={{currency}}",
              "host": ["{{bffBaseUrl}}"],
              "path": ["api", "vas", "catalog", "products", "{{productId}}"],
              "query": [{ "key": "currency", "value": "{{currency}}" }]
            }
          }
        }
      ]
    },
    {
      "name": "Catalog — quick picks",
      "description": "Shortcuts with `serviceId` pre-set. Set `countryCode=ZW` and run **Product by id** from Catalog when needed.",
      "item": [
        {
          "name": "Airtime — all-network products (service 1)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{bffBaseUrl}}/api/vas/catalog/products?countryCode={{countryCode}}&service=1&serviceProvider=HR_AllNetworks,Econet,NetOne,Telecel",
              "host": ["{{bffBaseUrl}}"],
              "path": ["api", "vas", "catalog", "products"],
              "query": [
                { "key": "countryCode", "value": "{{countryCode}}" },
                { "key": "service", "value": "1" },
                { "key": "serviceProvider", "value": "HR_AllNetworks,Econet,NetOne,Telecel" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('serviceId', '1');",
                  "const j = pm.response.json();",
                  "if (j.Products && j.Products.length) {",
                  "  pm.environment.set('productId', 'HR_100_100');",
                  "  pm.environment.set('productIdAirtime', 'HR_100_100');",
                  "}"
                ]
