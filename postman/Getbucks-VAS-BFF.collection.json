    },
    {
      "name": "VAS Payment",
      "description": "⚠️ Live upstream — Validate then Post may charge real funds. `requestId` is a new GUID each request (collection pre-request).",
      "item": [
        {
          "name": "Validate payment (airtime)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Amount\": {{paymentAmount}},\n  \"Currency\": \"{{currency}}\",\n  \"ProductId\": \"{{productIdAirtime}}\",\n  \"RequestId\": \"{{requestId}}\",\n  \"Quantity\": 1,\n  \"BillReferenceNumber\": \"bff-validate\",\n  \"CustomerDetails\": {\n    \"CustomerId\": \"postman\",\n    \"Fullname\": \"Postman Test\",\n    \"MobileNumber\": \"{{mobileNumberLocal}}\",\n    \"EmailAddress\": \"test@example.com\"\n  },\n  \"POSDetails\": {\n    \"CashierId\": \"1\",\n    \"StoreId\": \"1\",\n    \"TerminalId\": \"1\"\n  },\n  \"CreditPartyIdentifiers\": [\n    {\n      \"IdentifierFieldName\": \"AccountNumber\",\n      \"IdentifierFieldValue\": \"{{mobileNumber}}\"\n    }\n  ]\n}",
