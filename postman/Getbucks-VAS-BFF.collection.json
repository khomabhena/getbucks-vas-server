        {
          "name": "Bundles — product HR_111_1HDBUS5",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{bffBaseUrl}}/api/vas/catalog/products/HR_111_1HDBUS5"
          }
        },
        {
          "name": "Electricity products (service 6)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{bffBaseUrl}}/api/vas/catalog/products?countryCode={{countryCode}}&service=6",
              "host": ["{{bffBaseUrl}}"],
              "path": ["api", "vas", "catalog", "products"],
              "query": [
                { "key": "countryCode", "value": "{{countryCode}}" },
                { "key": "service", "value": "6" }
              ]
            }
          }
        },
        {
          "name": "Entertainment / DSTV (service 13)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{bffBaseUrl}}/api/vas/catalog/products?countryCode={{countryCode}}&service=13",
              "host": ["{{bffBaseUrl}}"],
              "path": ["api", "vas", "catalog", "products"],
              "query": [
                { "key": "countryCode", "value": "{{countryCode}}" },
