              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/V2/GetVASAccountBalance"
          }
        }
      ]
    },
    {
      "name": "Admin (use with caution)",
      "description": "⚠️ Can change live product catalog. Disabled by default in Postman — enable query/body only when intended.",
      "item": [
        {
          "name": "Refresh products (aggregator 7)",
          "request": {
            "method": "POST",
