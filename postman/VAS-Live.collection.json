          }
        }
      ]
    },
    {
      "name": "Payments",
      "description": "⚠️ Live environment — PostPayment may charge real funds. Uses fresh `requestId` each run.",
      "item": [
        {
          "name": "Validate payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/plain" },
              { "key": "Ocp-Apim-Subscription-Key", "value": "{{subscriptionKey}}" },
              { "key": "MerchantId", "value": "{{merchantId}}" },
              { "key": "RequestTimestamp", "value": "{{requestTimestamp}}" },
              { "key": "Signature", "value": "{{signature}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Amount\": {{paymentAmount}},\n  \"Currency\": \"{{currency}}\",\n  \"ProductId\": \"{{productIdAirtime}}\",\n  \"RequestId\": \"{{requestId}}\",\n  \"Quantity\": 1,\n  \"BillReferenceNumber\": \"test-validate\",\n  \"CustomerDetails\": {\n    \"CustomerId\": \"test\",\n    \"Fullname\": \"Test User\",\n    \"MobileNumber\": \"{{mobileNumberLocal}}\",\n    \"EmailAddress\": \"test@example.com\"\n  },\n  \"POSDetails\": {\n    \"CashierId\": \"1\",\n    \"StoreId\": \"1\",\n    \"TerminalId\": \"1\"\n  },\n  \"CreditPartyIdentifiers\": [\n    {\n      \"IdentifierFieldName\": \"AccountNumber\",\n      \"IdentifierFieldValue\": \"{{mobileNumber}}\"\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/V2/ValidatePayment"
          }
        },
        {
          "name": "Post payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/plain" },
              { "key": "Ocp-Apim-Subscription-Key", "value": "{{subscriptionKey}}" },
              { "key": "MerchantId", "value": "{{merchantId}}" },
              { "key": "RequestTimestamp", "value": "{{requestTimestamp}}" },
              { "key": "Signature", "value": "{{signature}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Amount\": {{paymentAmount}},\n  \"Currency\": \"{{currency}}\",\n  \"ProductId\": \"{{productIdAirtime}}\",\n  \"RequestId\": \"{{requestId}}\",\n  \"Quantity\": 1,\n  \"PaymentChannel\": \"API\",\n  \"PaymentReferenceNumber\": \"postman-test\",\n  \"BillReferenceNumber\": \"postman-test\",\n  \"CustomerDetails\": {\n    \"CustomerId\": \"test\",\n    \"Fullname\": \"Test User\",\n    \"MobileNumber\": \"{{mobileNumberLocal}}\",\n    \"EmailAddress\": \"test@example.com\"\n  },\n  \"POSDetails\": {\n    \"CashierId\": \"1\",\n    \"StoreId\": \"1\",\n    \"TerminalId\": \"1\"\n  },\n  \"CreditPartyIdentifiers\": [\n    {\n      \"IdentifierFieldName\": \"AccountNumber\",\n      \"IdentifierFieldValue\": \"{{mobileNumber}}\"\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/V2/PostPayment"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.RequestId) {",
                  "    pm.environment.set('samplePaymentRequestId', j.RequestId);",
                  "    console.log('Saved samplePaymentRequestId:', j.RequestId);",
                  "  }",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "Payment status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "text/plain" },
              { "key": "Ocp-Apim-Subscription-Key", "value": "{{subscriptionKey}}" },
              { "key": "MerchantId", "value": "{{merchantId}}" },
              { "key": "RequestTimestamp", "value": "{{requestTimestamp}}" },
              { "key": "Signature", "value": "{{signature}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/V2/PaymentStatus?id={{samplePaymentRequestId}}",
              "host": ["{{baseUrl}}"],
              "path": ["V2", "PaymentStatus"],
              "query": [{ "key": "id", "value": "{{samplePaymentRequestId}}" }]
            }
          }
        },
        {
          "name": "Reverse payment",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "text/plain" },
              { "key": "Ocp-Apim-Subscription-Key", "value": "{{subscriptionKey}}" },
              { "key": "MerchantId", "value": "{{merchantId}}" },
              { "key": "RequestTimestamp", "value": "{{requestTimestamp}}" },
              { "key": "Signature", "value": "{{signature}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/V2/ReversePayment?id={{samplePaymentRequestId}}",
              "host": ["{{baseUrl}}"],
              "path": ["V2", "ReversePayment"],
              "query": [{ "key": "id", "value": "{{samplePaymentRequestId}}" }]
            }
          }
        },
        {
          "name": "Get last token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/plain" },
              { "key": "Ocp-Apim-Subscription-Key", "value": "{{subscriptionKey}}" },
              { "key": "MerchantId", "value": "{{merchantId}}" },
              { "key": "RequestTimestamp", "value": "{{requestTimestamp}}" },
              { "key": "Signature", "value": "{{signature}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ProductId\": \"{{productIdDstv}}\",\n  \"CreditPartyIdentifiers\": [\n    {\n      \"IdentifierFieldName\": \"AccountNumber\",\n      \"IdentifierFieldValue\": \"{{mobileNumber}}\"\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/V2/GetLastToken"
          }
        }
      ]
    },
    {
      "name": "Account",
      "item": [
        {
          "name": "Get VAS account balance",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "text/plain" },
              { "key": "Ocp-Apim-Subscription-Key", "value": "{{subscriptionKey}}" },
