    },
    {
      "name": "Other",
      "item": [
        {
          "name": "Connect (health)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/V2/Connect"
          }
        },
        {
          "name": "Service providers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "text/plain" },
              { "key": "Ocp-Apim-Subscription-Key", "value": "{{subscriptionKey}}" },
              { "key": "MerchantId", "value": "{{merchantId}}" },
              { "key": "RequestTimestamp", "value": "{{requestTimestamp}}" },
              { "key": "Signature", "value": "{{signature}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/V2/ServiceProviders?countryCode={{countryCode}}&service={{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["V2", "ServiceProviders"],
              "query": [
                { "key": "countryCode", "value": "{{countryCode}}", "disabled": true },
                { "key": "service", "value": "{{serviceId}}", "disabled": true }
              ]
            }
          }
        },
        {
